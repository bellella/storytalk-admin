{
  "scenes": [
    {
      "title": "Victory Calls",
      "koreanTitle": "승리의 전화 폭탄",
      "order": 1,
      "dialogues": [
        {
          "order": 1,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley sits on the train, staring at her phone with a huge smile.",
          "koreanText": "라일리는 기차 좌석에 앉아 휴대폰을 보며 활짝 웃고 있다.",
          "imageUrl": null
        },
        {
          "order": 2,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "Okay, who should I call first? Mom? Dad? My dentist?",
          "koreanText": "좋아, 누구부터 전화하지? 엄마? 아빠? 치과 선생님?",
          "imageUrl": null
        },
        {
          "order": 3,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "No. Best friend energy first.",
          "koreanText": "아니. 베프부터다.",
          "imageUrl": null
        },
        {
          "order": 4,
          "type": "dialogue",
          "characterName": "Friend",
          "charImageLabel": null,
          "englishText": "Hello?",
          "koreanText": "여보세요?",
          "imageUrl": null
        },
        {
          "order": 5,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "I PASSED.",
          "koreanText": "나 합격했어.",
          "imageUrl": null
        },
        {
          "order": 6,
          "type": "dialogue",
          "characterName": "Friend",
          "charImageLabel": null,
          "englishText": "YOU WHAT?!",
          "koreanText": "뭐라고?!",
          "imageUrl": null
        },
        {
          "order": 7,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley hangs up and immediately dials another number.",
          "koreanText": "라일리는 전화를 끊자마자 또 다른 번호를 누른다.",
          "imageUrl": null
        },
        {
          "order": 8,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "Guess who just passed her audition?",
          "koreanText": "누가 오디션 합격했게?",
          "imageUrl": null
        },
        {
          "order": 9,
          "type": "dialogue",
          "characterName": "Friend",
          "charImageLabel": null,
          "englishText": "YOU?!",
          "koreanText": "너?!",
          "imageUrl": null
        },
        {
          "order": 10,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "ME.",
          "koreanText": "나.",
          "imageUrl": null
        },
        {
          "order": 11,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley leans back in her seat, glowing.",
          "koreanText": "라일리는 의자에 기대며 환하게 웃는다.",
          "imageUrl": null
        },
        {
          "order": 12,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "Also, Prince? Total pain.",
          "koreanText": "근데 프린스? 진짜 밥맛이야.",
          "imageUrl": null
        },
        {
          "order": 13,
          "type": "dialogue",
          "characterName": "Friend",
          "charImageLabel": null,
          "englishText": "Wait, THE Prince?",
          "koreanText": "잠깐, 그 프린스?",
          "imageUrl": null
        },
        {
          "order": 14,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "angry",
          "englishText": "Yes, that Prince. Acting like talent isn’t enough and looks aren’t everything.",
          "koreanText": "응, 그 프린스. 재능만으로는 부족하다는 둥, 얼굴이 전부가 아니라는 둥.",
          "imageUrl": null
        },
        {
          "order": 15,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "angry",
          "englishText": "Like, excuse me? My face worked very hard today.",
          "koreanText": "아니, 잠깐만요? 제 얼굴 오늘 엄청 열심히 일했거든요?",
          "imageUrl": null
        },
        {
          "order": 16,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "She laughs, shaking her head.",
          "koreanText": "라일리는 고개를 흔들며 웃는다.",
          "imageUrl": null
        }
      ]
    },
    {
      "title": "Home Sweet Home",
      "koreanTitle": "집에 도착",
      "order": 2,
      "dialogues": [
        {
          "order": 1,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "The train stops. Riley steps onto the platform, heart full.",
          "koreanText": "기차가 멈추고, 라일리는 설레는 마음으로 플랫폼에 내린다.",
          "imageUrl": null
        },
        {
          "order": 2,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "Riley!",
          "koreanText": "라일리!",
          "imageUrl": null
        },
        {
          "order": 3,
          "type": "dialogue",
          "characterName": "Dad",
          "charImageLabel": null,
          "englishText": "There she is!",
          "koreanText": "우리 딸이다!",
          "imageUrl": null
        },
        {
          "order": 4,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "They pull her into a tight hug.",
          "koreanText": "부모님은 라일리를 꽉 끌어안는다.",
          "imageUrl": null
        },
        {
          "order": 5,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "So? How did it go?",
          "koreanText": "그래? 어땠어?",
          "imageUrl": null
        },
        {
          "order": 6,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "I passed.",
          "koreanText": "합격했어.",
          "imageUrl": null
        },
        {
          "order": 7,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "You WHAT?",
          "koreanText": "뭐라고?!",
          "imageUrl": null
        },
        {
          "order": 8,
          "type": "dialogue",
          "characterName": "Dad",
          "charImageLabel": null,
          "englishText": "That’s amazing!",
          "koreanText": "대단하다!",
          "imageUrl": null
        },
        {
          "order": 9,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley smiles, then hesitates.",
          "koreanText": "라일리는 웃다가 잠시 망설인다.",
          "imageUrl": null
        },
        {
          "order": 10,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "default",
          "englishText": "But… the next round is in New York.",
          "koreanText": "근데… 다음 라운드는 뉴욕에서 해.",
          "imageUrl": null
        },
        {
          "order": 11,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "New York?",
          "koreanText": "뉴욕이라고?",
          "imageUrl": null
        },
        {
          "order": 12,
          "type": "dialogue",
          "characterName": "Dad",
          "charImageLabel": null,
          "englishText": "That’s not exactly close to Oklahoma.",
          "koreanText": "오클라호마랑은 꽤 먼데.",
          "imageUrl": null
        },
        {
          "order": 13,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "sad",
          "englishText": "Yeah… commuting isn’t really an option.",
          "koreanText": "응… 통근은 현실적으로 어렵지.",
          "imageUrl": null
        },
        {
          "order": 14,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Her parents exchange worried looks.",
          "koreanText": "부모님은 걱정스러운 눈빛을 주고받는다.",
          "imageUrl": null
        },
        {
          "order": 15,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "Are you sure this is what you want?",
          "koreanText": "정말 이게 네가 원하는 거니?",
          "imageUrl": null
        },
        {
          "order": 16,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "default",
          "englishText": "More than anything.",
          "koreanText": "그 무엇보다.",
          "imageUrl": null
        },
        {
          "order": 17,
          "type": "dialogue",
          "characterName": "Dad",
          "charImageLabel": null,
          "englishText": "Then we’ll make it work.",
          "koreanText": "그럼 우리가 도와줄게.",
          "imageUrl": null
        },
        {
          "order": 18,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "We believe in you.",
          "koreanText": "우리는 널 믿어.",
          "imageUrl": null
        },
        {
          "order": 19,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "Really?!",
          "koreanText": "진짜?!",
          "imageUrl": null
        },
        {
          "order": 20,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "I swear, I’ll win. I’ll be a superstar. You won’t regret this.",
          "koreanText": "진짜 1등해서 슈퍼스타 될게. 절대 후회 안 하게 할게.",
          "imageUrl": null
        }
      ]
    },
    {
      "title": "Pizza Shop Goodbye",
      "koreanTitle": "피자 가게와 작별",
      "order": 3,
      "dialogues": [
        {
          "order": 1,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Later that day, Riley walks into the pizza shop where she works.",
          "koreanText": "그날 저녁, 라일리는 자신이 일하던 피자 가게로 들어간다.",
          "imageUrl": null
        },
        {
          "order": 2,
          "type": "dialogue",
          "characterName": "Coworker",
          "charImageLabel": null,
          "englishText": "Hey Riley! You’re early.",
          "koreanText": "라일리! 오늘 일찍 왔네?",
          "imageUrl": null
        },
        {
          "order": 3,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "default",
          "englishText": "Actually… I won’t be coming in anymore.",
          "koreanText": "사실… 이제 여기 못 나와.",
          "imageUrl": null
        },
        {
          "order": 4,
          "type": "dialogue",
          "characterName": "Coworker",
          "charImageLabel": null,
          "englishText": "Wait, what? Why?",
          "koreanText": "뭐? 왜?",
          "imageUrl": null
        },
        {
          "order": 5,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "I passed a big audition. Next round’s in New York.",
          "koreanText": "큰 오디션에 합격했어. 다음 라운드는 뉴욕이야.",
          "imageUrl": null
        },
        {
          "order": 6,
          "type": "dialogue",
          "characterName": "Boss",
          "charImageLabel": null,
          "englishText": "That’s huge!",
          "koreanText": "그거 엄청난 일이잖아!",
          "imageUrl": null
        },
        {
          "order": 7,
          "type": "dialogue",
          "characterName": "Coworker",
          "charImageLabel": null,
          "englishText": "We’re gonna see you on TV.",
          "koreanText": "우리 너 TV에서 보게 되는 거야?",
          "imageUrl": null
        },
        {
          "order": 8,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "happy",
          "englishText": "Don’t jinx it.",
          "koreanText": "김칫국 마시지 마.",
          "imageUrl": null
        },
        {
          "order": 9,
          "type": "dialogue",
          "characterName": "Boss",
          "charImageLabel": null,
          "englishText": "You’ll do great. Don’t forget us little people.",
          "koreanText": "잘될 거야. 우리 같은 소시민들 잊지 말고.",
          "imageUrl": null
        },
        {
          "order": 10,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley laughs, eyes shining.",
          "koreanText": "라일리는 눈을 반짝이며 웃는다.",
          "imageUrl": null
        }
      ]
    },
    {
      "title": "The TV Announcement",
      "koreanTitle": "충격적인 TV 발표",
      "order": 4,
      "dialogues": [
        {
          "order": 1,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "That night, Riley sits on the couch with her parents, still smiling.",
          "koreanText": "그날 밤, 라일리는 부모님과 소파에 앉아 여전히 웃고 있다.",
          "imageUrl": null
        },
        {
          "order": 2,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "The TV suddenly switches to an audition commercial.",
          "koreanText": "TV에서 갑자기 오디션 광고가 나온다.",
          "imageUrl": null
        },
        {
          "order": 3,
          "type": "dialogue",
          "characterName": "TV Announcer",
          "charImageLabel": null,
          "englishText": "We are gathering talented stars from across the nation for an all-new survival camp!",
          "koreanText": "전국의 잠재력 있는 스타들을 모아 새로운 합숙 서바이벌을 시작합니다!",
          "imageUrl": null
        },
        {
          "order": 4,
          "type": "dialogue",
          "characterName": "TV Announcer",
          "charImageLabel": null,
          "englishText": "Only the strongest will survive.",
          "koreanText": "오직 가장 강한 참가자만 살아남습니다.",
          "imageUrl": null
        },
        {
          "order": 5,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley’s smile slowly disappears.",
          "koreanText": "라일리의 미소가 서서히 사라진다.",
          "imageUrl": null
        },
        {
          "order": 6,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "sad",
          "englishText": "Wait… survival?",
          "koreanText": "잠깐… 서바이벌이라고?",
          "imageUrl": null
        },
        {
          "order": 7,
          "type": "dialogue",
          "characterName": "Mom",
          "charImageLabel": null,
          "englishText": "That sounds intense.",
          "koreanText": "되게 빡셀 것 같은데.",
          "imageUrl": null
        },
        {
          "order": 8,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "sad",
          "englishText": "Those shows ruin people.",
          "koreanText": "그런 프로그램 사람 인생 망치기도 해.",
          "imageUrl": null
        },
        {
          "order": 9,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "sad",
          "englishText": "What if I mess up? What if I get hated?",
          "koreanText": "내가 실수하면 어떡하지? 욕먹으면?",
          "imageUrl": null
        },
        {
          "order": 10,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Her heart starts racing again — but this time, not from excitement.",
          "koreanText": "이번엔 설렘이 아니라 불안 때문에 심장이 빨리 뛴다.",
          "imageUrl": null
        },
        {
          "order": 11,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "sad",
          "englishText": "How many terrifyingly talented people are out there?",
          "koreanText": "세상에 무서운 실력자들이 얼마나 많을까…",
          "imageUrl": null
        },
        {
          "order": 12,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "Riley stares at the screen.",
          "koreanText": "라일리는 TV 화면을 멍하니 바라본다.",
          "imageUrl": null
        },
        {
          "order": 13,
          "type": "dialogue",
          "characterName": "Riley",
          "charImageLabel": "default",
          "englishText": "Can a girl from Oklahoma really survive this?",
          "koreanText": "오클라호마에서 온 내가… 과연 살아남을 수 있을까?",
          "imageUrl": null
        },
        {
          "order": 14,
          "type": "narration",
          "characterName": "",
          "charImageLabel": null,
          "englishText": "The screen fades to black.",
          "koreanText": "화면이 천천히 어두워진다.",
          "imageUrl": null
        }
      ]
    }
  ]
}
